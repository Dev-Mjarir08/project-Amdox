{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/server.js",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    {
      "source": "/_/backend/:match*",
      "destination": "/_/backend/:match*"
    },
    {
      "source": "/((?!_/).*)",
      "destination": "/index.html"
    }
  ]
}